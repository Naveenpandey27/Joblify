# =========================
# NexJob Root .gitignore
# =========================

# ----- Python / Backend -----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environment
backend/venv/
venv/
.venv/
env/

# Environment variables (SECRETS - NEVER PUSH)
.env
.env.local
.env.*.local
backend/.env

# ----- Node / Frontend -----
node_modules/
.next/
out/
build/
.vercel
*.tsbuildinfo
next-env.d.ts

# ----- OS Files -----
.DS_Store
Thumbs.db
desktop.ini

# ----- IDE -----
.vscode/
.idea/
*.swp
*.swo
*~

# ----- Logs -----
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- Test Files -----
/coverage
*.pem
test_resume.pdf
